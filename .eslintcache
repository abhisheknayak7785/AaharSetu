:0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"85","messages":"86","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"87","messages":"88","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"89"},{"filePath":"90","messages":"91","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"92","messages":"93","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"94","messages":"95","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\DigitalRationDistributionSystem\\RationApp\\src\\index.js",[],["96","97"],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\reportWebVitals.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\App.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\shopkeeper.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\login.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\admin.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\register.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\home.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\white-ration.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\saffron-ration.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\about.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\yellow-ration.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\complaint.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\navbar.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\contact.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\shopkeeper\\ss-dashboard.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\shopkeeper\\ss-user-details.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\shopkeeper\\ss-stock-details.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\admin\\adminProfile.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\shopkeeper\\ssprofile.js",["98"],"import React, { useState, useEffect } from 'react';\nimport axios from 'axios';\nimport DatePicker from \"react-datepicker\";\nimport \"react-datepicker/dist/react-datepicker.css\";\n\nconst validEmailRegex = /^(([^<>()[\\].,;:\\s@\"]+(\\.[^<>()[\\].,;:\\s@\"]+)*)|(\".+\"))@(([^<>()[\\].,;:\\s@\"]+\\.)+[^<>()[\\].,;:\\s@\"]{2,})$/i;\nconst phonePattern = /^\\d{10}$/;\n\nconst Ssprofile = (props) => {\n    const [firstname, setFirstname] = useState('');\n    const [lastname, setLastname] = useState('');\n    const [mobileno, setMobileno] = useState('');\n    const [email, setEmail] = useState('');\n    const [username, setUsername] = useState('');\n    const [dob, setDob] = useState(new Date());\n    const [gender, setGender] = useState('');\n    const [password, setPassword] = useState('');\n    const [errorMessage, setErrorMessage] = useState('');\n    const [errors, setErrors] = useState({\n        username: '', email: '', password: '', mobileno: ''\n    });\n\n    useEffect(() => {\n        if (props.match && props.match.params.username) {\n            axios.get(\"http://localhost:5000/shopkeeper/ssprofile/\" + props.match.params.username)\n                .then(res => {\n                    setFirstname(res.data.firstname || '');\n                    setLastname(res.data.lastname || '');\n                    setMobileno(res.data.mobileno || '');\n                    setEmail(res.data.email || '');\n                    setUsername(res.data.username || '');\n                    setPassword(res.data.password || '');\n                    setGender(res.data.duration || '');\n                    setDob(new Date(res.data.dob));\n                })\n                .catch(err => console.log(err));\n        }\n    }, [props.match]);\n\n    const validate = (name, value) => {\n        const newErrors = { ...errors };\n        switch (name) {\n            case 'username':\n                newErrors.username = value.length < 5 ? 'Username must be at least 5 characters long!' : '';\n                break;\n            case 'mobileno':\n                newErrors.mobileno = phonePattern.test(value) ? '' : 'Mobile no is not valid!';\n                break;\n            case 'email':\n                newErrors.email = validEmailRegex.test(value) ? '' : 'Email is not valid!';\n                break;\n            case 'password':\n                newErrors.password = value.length < 6 ? 'Password must be at least 6 characters long!' : '';\n                break;\n            default:\n                break;\n        }\n        setErrors(newErrors);\n    };\n\n    const onSubmit = async (e) => {\n        e.preventDefault();\n        const user = { firstname, lastname, mobileno, email, username, dob: Date.parse(dob), gender, password };\n\n        if (props.match && props.match.params.id) {\n            axios.post('http://localhost:5000/shopkeeper/ssprofile/update/' + props.match.params.id, user)\n                .then(res => console.log(res.data));\n        }\n    };\n\n    return (\n        <div className=\"fade-in-up\">\n            <h2 className=\"section-title\">Profile Details</h2>\n            <div style={{ maxWidth: 540 }}>\n                <div className=\"form-card\">\n                    <form onSubmit={onSubmit}>\n                        <div className=\"form-row\">\n                            <div className=\"form-group\">\n                                <label htmlFor=\"ss-firstname\">First Name</label>\n                                <input type=\"text\" id=\"ss-firstname\" className=\"form-input\" placeholder=\"First name\"\n                                    required value={firstname} onChange={(e) => setFirstname(e.target.value)} />\n                            </div>\n                            <div className=\"form-group\">\n                                <label htmlFor=\"ss-lastname\">Last Name</label>\n                                <input type=\"text\" id=\"ss-lastname\" className=\"form-input\" placeholder=\"Last name\"\n                                    required value={lastname} onChange={(e) => setLastname(e.target.value)} />\n                            </div>\n                        </div>\n\n                        <div className=\"form-group\">\n                            <label htmlFor=\"ss-mobile\">Mobile Number</label>\n                            <input type=\"tel\" id=\"ss-mobile\" className=\"form-input\" placeholder=\"10-digit mobile\"\n                                required autoComplete=\"off\" maxLength=\"10\" inputMode=\"tel\"\n                                value={mobileno}\n                                onChange={(e) => { setMobileno(e.target.value); validate('mobileno', e.target.value); }} />\n                            {errors.mobileno && <div className=\"form-error\">{errors.mobileno}</div>}\n                        </div>\n\n                        <div className=\"form-group\">\n                            <label htmlFor=\"ss-email\">Email Address</label>\n                            <input type=\"text\" id=\"ss-email\" className=\"form-input\" placeholder=\"you@example.com\"\n                                required value={email}\n                                onChange={(e) => { setEmail(e.target.value); validate('email', e.target.value); }} />\n                            {errors.email && <div className=\"form-error\">{errors.email}</div>}\n                            {errorMessage && <div className=\"form-error\">{errorMessage}</div>}\n                        </div>\n\n                        <div className=\"form-group\">\n                            <label htmlFor=\"ss-username\">Username</label>\n                            <input type=\"text\" id=\"ss-username\" className=\"form-input\" placeholder=\"Username\"\n                                required value={username}\n                                onChange={(e) => { setUsername(e.target.value); validate('username', e.target.value); }} />\n                            {errors.username && <div className=\"form-error\">{errors.username}</div>}\n                        </div>\n\n                        <div className=\"form-group\">\n                            <label>Date of Birth</label>\n                            <DatePicker\n                                placeholderText=\"Select date of birth\"\n                                dateFormat=\"dd/MM/yyyy\"\n                                autoComplete=\"off\"\n                                selected={dob}\n                                onChange={(date) => setDob(date)}\n                            />\n                        </div>\n\n                        <div className=\"form-group\">\n                            <label>Gender</label>\n                            <div className=\"radio-group\">\n                                <label className=\"radio-label\">\n                                    <input type=\"radio\" name=\"gender\" value=\"Male\"\n                                        checked={gender === 'Male'} onChange={(e) => setGender(e.target.value)} />\n                                    Male\n                                </label>\n                                <label className=\"radio-label\">\n                                    <input type=\"radio\" name=\"gender\" value=\"Female\"\n                                        checked={gender === 'Female'} onChange={(e) => setGender(e.target.value)} />\n                                    Female\n                                </label>\n                                <label className=\"radio-label\">\n                                    <input type=\"radio\" name=\"gender\" value=\"Other\"\n                                        checked={gender === 'Other'} onChange={(e) => setGender(e.target.value)} />\n                                    Other\n                                </label>\n                            </div>\n                        </div>\n\n                        <div className=\"form-group\">\n                            <label htmlFor=\"ss-password\">Password</label>\n                            <input type=\"password\" id=\"ss-password\" className=\"form-input\" placeholder=\"Password\"\n                                required value={password}\n                                onChange={(e) => { setPassword(e.target.value); validate('password', e.target.value); }} />\n                            {errors.password && <div className=\"form-error\">{errors.password}</div>}\n                        </div>\n\n                        <button type=\"submit\" className=\"btn-primary-gradient\">\n                            <span className=\"material-icons-round\" style={{ fontSize: '1.1rem' }}>save</span>\n                            Update Profile\n                        </button>\n                    </form>\n                </div>\n            </div>\n        </div>\n    );\n};\n\nexport default Ssprofile;","D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\admin\\adminDashboard.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\admin\\adminShopkeeperDetails.js",[],"D:\\DigitalRationDistributionSystem\\RationApp\\src\\components\\admin\\adminComplaint.js",[],{"ruleId":"99","replacedBy":"100"},{"ruleId":"101","replacedBy":"102"},{"ruleId":"103","severity":1,"message":"104","line":18,"column":26,"nodeType":"105","messageId":"106","endLine":18,"endColumn":41},"no-native-reassign",["107"],"no-negated-in-lhs",["108"],"no-unused-vars","'setErrorMessage' is assigned a value but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]